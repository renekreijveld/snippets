<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Snippets\Component\Snippets\Site\Field">
    <fieldset>
        <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC" />
        <field name="state" default="1" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field name="ordering" />
        <field name="checked_out" type="hidden" filter="unset" />
        <field name="checked_out_time" type="hidden" filter="unset" />
        <field name="cat_id" type="snippetcategory" required="true" message="Category missing" label="SNIPPETS_FORM_LBL_SNIPPET_CAT_ID" />
        <field name="title" filter="safehtml" type="text" required="true" label="JGLOBAL_TITLE" description="" hint="SNIPPETS_FORM_LBL_SNIPPET_TITLE" />
        <field name="alias" type="text" class="inputbox" generator="title" label="JFIELD_ALIAS_LABEL" description="JFIELD_ALIAS_DESC" hint="SNIPPETS_FORM_LBL_SNIPPET_ALIAS" />
        <field name="content" buttons="false" filter="RAW" type="editor" editor="codemirror|tinymce" label="SNIPPETS_FORM_LBL_SNIPPET_CONTENT" description="SNIPPETS_FORM_DESC_SNIPPET_CONTENT" hint="SNIPPETS_FORM_LBL_SNIPPET_CONTENT" />
        <field name="target" default="1" type="radio" required="true" label="SNIPPETS_FORM_LBL_SNIPPET_TARGET" description="SNIPPETS_FORM_DESC_SNIPPET_TARGET" class="btn-group" hint="SNIPPETS_FORM_LBL_SNIPPET_TARGET">
            <option value="1">SNIPPETS_SNIPPETS_TARGET_OPTION_1</option>
            <option value="0">SNIPPETS_SNIPPETS_TARGET_OPTION_0</option>
        </field>
        <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label" />
    </fieldset>
</form>
