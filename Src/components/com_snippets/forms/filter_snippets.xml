<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" hint="SNIPPETS_SEARCH_FILTER_SUBMIT" label="COM_USERS_FILTER_SEARCH_DESC" class="js-stools-search-string" />
        <field name="cat_id" label="SNIPPETS_FORM_LBL_SNIPPET_CAT_ID" type="category" extension="com_snippets.snippets" onchange="this.form.submit();" multiple="true" class="js-select-submit-on-change" hint="JOPTION_SELECT_CATEGORY"/>
    </fields>
    <fields name="list">
        <field name="fullordering" type="list" label="SNIPPETS_LIST_FULL_ORDERING" description="SNIPPETS_LIST_FULL_ORDERING_DESC" onchange="this.form.submit();" default="a.id DESC">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">SNIPPETS_ID_ASC</option>
            <option value="a.id DESC">SNIPPETS_ID_DESC</option>
            <option value="a.state ASC">SNIPPETS_STATE_ASC</option>
            <option value="a.state DESC">SNIPPETS_STATE_DESC</option>
            <option value="a.ordering ASC">SNIPPETS_ORDERING_ASC</option>
            <option value="a.ordering DESC">SNIPPETS_ORDERING_DESC</option>
            <option value="a.cat_id ASC">SNIPPETS_CAT_ID_ASC</option>
            <option value="a.cat_id DESC">SNIPPETS_CAT_ID_DESC</option>
            <option value="a.title ASC">SNIPPETS_TITLE_ASC</option>
            <option value="a.title DESC">SNIPPETS_TITLE_DESC</option>
            <option value="a.alias ASC">SNIPPETS_ALIAS_ASC</option>
            <option value="a.alias DESC">SNIPPETS_ALIAS_DESC</option>
            <option value="a.target ASC">SNIPPETS_TARGET_ASC</option>
            <option value="a.target DESC">SNIPPETS_TARGET_DESC</option>
        </field>
        <field name="limit" type="limitbox" label="SNIPPETS_LIST_LIMIT" description="SNIPPETS_LIST_LIMIT_DESC" class="input-mini" default="25" onchange="this.form.submit();" />
    </fields>
</form>